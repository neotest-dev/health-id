{
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api/|assets/|@|src/|node_modules/|favicon.ico|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
